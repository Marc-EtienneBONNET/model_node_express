API_PORT=3000
DEFAULT_LANGAGE=fr
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:2000

# Comma-separated list of allowed CORS origins for browser clients.
# If empty/unset, allows all origins (dev-friendly). Set strictly in prod.
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://app.exemple.com

DATABASE_URL=postgresql://user:pass@localhost:9000/db?schema=public # DB dans un docker 
# DATABASE_URL=postgresql://user:pass@localhost:9000/db?schema=public # DB db sur google 
